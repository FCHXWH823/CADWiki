# Get your free Portkey API key at https://app.portkey.ai
# Connect it to OpenAI, Anthropic, or Gemini in the Portkey dashboard
PORTKEY_API_KEY=your-portkey-api-key-here

# Gateway URL — leave blank for public Portkey, or use NYU gateway on VPN:
# PORTKEY_BASE_URL=https://ai-gateway.apps.cloud.rt.nyu.edu/v1
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
