# NYU AI Gateway key (works against the gateway below, which is publicly reachable)
PORTKEY_API_KEY=your-nyu-portkey-api-key-here

# Gateway URL — defaults to the NYU AI Gateway (no VPN needed; it is publicly reachable).
# Override only if you use a different Portkey-compatible gateway.
PORTKEY_BASE_URL=https://ai-gateway.apps.cloud.rt.nyu.edu/v1

# Comma-separated allowed frontend origins, or "*" to allow all (public site)
ALLOWED_ORIGINS=*
